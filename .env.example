# Demand Engine 2.0 — environment variables
# Same Supabase + keys as v1. Copy to .env.local and fill in.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (required: all Claude calls — decode, generate, synthesize) ---
ANTHROPIC_API_KEY=

# --- OpenAI (required only for /api/spy/generate-image) ---
OPENAI_API_KEY=

# --- Meta Ad Library (required for Source: /api/spy/search, /api/spy/pages) ---
# Lives in Vercel as META_ACCESS_TOKEN. Paste here to pull live ads locally.
META_ACCESS_TOKEN=

# --- Admin / machine auth (gates /api/spy/*) ---
ADMIN_PASSWORD=
INTERNAL_API_SECRET=
MACHINE_API_KEY=

# --- T2V engine (Rebuild -> video render handoff) ---
# Base URL of the separate T2V app. Lives in Vercel as T2V_ENGINE_URL.
T2V_ENGINE_URL=
# Optional: if set, the T2V webhook must include ?key=<this> to be accepted.
T2V_WEBHOOK_SECRET=
