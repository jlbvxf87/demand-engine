# Demand Engine 2.0 — environment variables
# Same Supabase + keys as v1. Copy to .env.local and fill in.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (required: all Claude calls — decode, generate, synthesize) ---
ANTHROPIC_API_KEY=

# --- OpenAI (required only for /api/spy/generate-image) ---
OPENAI_API_KEY=

# --- Meta Ad Library (required for Source: /api/spy/search, /api/spy/pages) ---
# Lives in Vercel as META_ACCESS_TOKEN. Paste here to pull live ads locally.
META_ACCESS_TOKEN=

# --- Admin / machine auth (gates /api/spy/*) ---
ADMIN_PASSWORD=
INTERNAL_API_SECRET=
MACHINE_API_KEY=

# --- Video generation (kie.ai, direct) ---
# One key powers all video models (seedance / kling / sora / veo / runway).
KIE_API_KEY=
KIE_API_BASE_URL=https://api.kie.ai

# --- Multi-scene stitch worker (separate ffmpeg service: de-stitch-worker) ---
# Base URL of the worker that concatenates storyboard scene clips into one video.
STITCH_WORKER_URL=
# Optional: if set, the stitch callback must include ?key=<this> to be accepted.
STITCH_WEBHOOK_SECRET=
